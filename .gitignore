*.py[cod]
*$py.class

# Ignore OS files
.DS_Store
Thumbs.db

# Keep reports (if smaller than 50MB)
!reports/
!reports/*.csv
node_modules
.next
.gemini/
.env
.env.local
.venv
venv/
out/
build/
dist/
